@model Sitecore.AspNetCore.Starter.Models.Blog.BlogDetailModel
@using Sitecore.AspNetCore.SDK.RenderingEngine.Extensions

<link rel="stylesheet" href="~/assets/css/components/blog-detail.css" asp-append-version="true" />

<article class="blog-detail container py-5">
    <header class="blog-header text-center mb-5 mx-auto" style="max-width: 800px;">
        <h1 class="blog-title display-4 fw-bold mb-3 text-dark">
            <sc-text asp-for="Title" />
        </h1>

        <div class="blog-meta text-muted mb-4 d-flex align-items-center justify-content-center gap-2 small text-uppercase fw-semibold">
            <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill mb-1" style="background-color: rgba(13, 110, 253, 0.1);">News</span>
            <span>&bull;</span>
            <span>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
        </div>
    </header>

    @if (Model?.Thumbnail?.Value != null)
    {
        <div class="blog-thumbnail mb-5 px-md-4">
            <img src="@Model?.Thumbnail?.Value.Src" class="img-fluid rounded-5 shadow-lg w-100" style="max-height: 600px; object-fit: cover;" alt="Thumbnail" />
        </div>
    }

    <div class="blog-content mx-auto px-3">
        @if (Model?.ContentBody != null)
        {
            <div class="rich-text-container text-secondary">
                @Html.Raw(Model.ContentBody.Value)
            </div>
        }
        
    </div>
</article>