@using Sitecore.AspNetCore.Starter.Models.Blog
@model SortDropdownModel

@{
    var currentSort = Context.Request.Query["sort"].ToString();
}

@if (Model?.Options != null && Model.Options.Any())
{
    <div class="d-flex align-items-center justify-content-md-end gap-3 mb-4">

        <label for="blogSortSelect"
               class="small text-muted fw-bold mb-0"
               style="letter-spacing:1px;">
            Sort by:
        </label>

        <div class="position-relative">

            <select id="blogSortSelect"
                    class="form-select form-select-sm border-0 shadow-sm rounded-pill ps-3 pe-5 py-2 text-dark fw-medium"
                    style="width:auto; min-width:180px; cursor:pointer; background-color:#f8f9fa;">

                @foreach (var option in Model.Options)
                {
                    bool isSelected =
                    (!string.IsNullOrEmpty(currentSort) && currentSort == option.Value)
                    || (string.IsNullOrEmpty(currentSort) && option.IsDefault);

                    <option value="@option.Value"
                            selected="@(isSelected ? "selected" : null)">
                        @option.Title
                    </option>
                }

            </select>

        </div>

    </div>
}

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const sortSelect = document.getElementById("blogSortSelect");

        if (!sortSelect) return;

        sortSelect.addEventListener("change", function () {

            const url = new URL(window.location.href);

            url.searchParams.set("sort", this.value);

            // reset page khi sort
            url.searchParams.set("page", "1");

            window.location.href = url.toString();

        });

    });

</script>