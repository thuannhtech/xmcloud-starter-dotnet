@model Sitecore.AspNetCore.Starter.Models.BannerSlider

@{
    bool isEditing = Model?.IsEditing ?? false;
    var slides = Model?.ChildSlides ?? (Model?.ImageGallery?.Select(i => new Sitecore.AspNetCore.Starter.Models.BannerSlider { SlideImage = i }).ToList()) ?? new List<Sitecore.AspNetCore.Starter.Models.BannerSlider>();
    
    // Add the current datasource item as a slide if it has fields on it
    if (Model?.SlideImage != null || Model?.SlideTitle != null) {
        slides.Insert(0, Model);
    }
}

<div class="component banner-slider @Model?.Styles @Model?.GridParameters" id="@Model?.Id">
    @if (isEditing)
    {
        <div class="banner-slider__editing-view">
            <h4 class="banner-editing-notice">Banner Slider (Editing Mode)</h4>
            @foreach (var slide in slides)
            {
                <div class="banner-slide-edit-item">
                     @if (slide.SlideImage != null) {
                        <div class="banner-slide__image-edit">
                            <sc-img asp-for="@slide.SlideImage" />
                        </div>
                     }
                     <div class="banner-slide__content">
                        <h1 class="banner-slide__title"><sc-text asp-for="@slide.SlideTitle" /></h1>
                        <p class="banner-slide__subtitle"><sc-text asp-for="@slide.SlideSubtitle" /></p>
                        <div class="banner-slide__cta"><sc-link asp-for="@slide.SlideLink" /></div>
                    </div>
                </div>
            }
            @if (!slides.Any())
            {
                <div class="banner-slide-placeholder">
                    <p>No slides found. Add child items or select images in the datasource.</p>
                    <div style="border: 1px dashed #ccc; padding: 20px;">
                        <sc-img asp-for="@Model.SlideImage" />
                        <sc-text asp-for="@Model.SlideTitle" />
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="swiper mySwiper">
            <div class="swiper-wrapper">
                @foreach (var slide in slides)
                {
                    <div class="swiper-slide">
                        <div class="banner-slide">
                            @if (slide.SlideImage != null)
                            {
                                <div class="banner-slide__image-container">
                                    <sc-img asp-for="@slide.SlideImage" />
                                </div>
                            }
                            <div class="banner-slide__overlay"></div>
                            <div class="banner-slide__content">
                                <h1 class="banner-slide__title"><sc-text asp-for="@slide.SlideTitle" /></h1>
                                <p class="banner-slide__subtitle"><sc-text asp-for="@slide.SlideSubtitle" /></p>
                                @if (slide.SlideLink != null)
                                {
                                    <div class="banner-slide__cta"><sc-link asp-for="@slide.SlideLink" /></div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var swiper = new Swiper(".mySwiper", {
                    navigation: {
                        nextEl: ".swiper-button-next",
                        prevEl: ".swiper-button-prev",
                    },
                    pagination: {
                        el: ".swiper-pagination",
                        clickable: true
                    },
                    loop: true,
                    autoplay: {
                        delay: 5000,
                        disableOnInteraction: false,
                    }
                });
            });
        </script>
    }
</div>
