@using Sitecore.AspNetCore.Starter.Models.Navigation
@model Sitecore.AspNetCore.Starter.Models.Navigation.Navigation

<style>
    /* Desktop Dropdown CSS */
    .component.navigation {
        font-family: inherit;
        position: relative;
        z-index: 100;
        background: #fff;
        width: 100%;
    }

    .nav-menu-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    /* Level 1 (Main Bar) */
    .nav-menu-list.level-1 {
        display: flex;
        align-items: center;
        gap: 32px;
        flex-wrap: wrap;
    }

    .nav-item {
        position: relative;
    }

    /* Title Wrapper */
    .nav-item .navigation-title {
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
    }

    /* Level 1 Links */
    .nav-menu-list.level-1 > .nav-item > .navigation-title > a {
        text-decoration: none;
        color: #111;
        font-size: 15px;
        padding: 16px 0;
        display: block;
        white-space: nowrap;
        font-weight: 500;
        transition: color 0.2s;
    }

    .nav-menu-list.level-1 > .nav-item:hover > .navigation-title > a {
        color: #003087; /* brother dark blue */
    }

    /* Chevron / Arrow Icon */
    .nav-arrow {
        width: 14px;
        height: 14px;
        color: #222;
        transition: transform 0.2s ease, color 0.2s;
        margin-top: 1px;
    }
    
    .nav-menu-list.level-1 > .nav-item:hover > .navigation-title > .nav-arrow {
        transform: rotate(180deg);
        color: #003087;
    }

    /* Dropdowns (Level 2+) */
    .nav-item > .nav-menu-list:not(.level-1) {
        position: absolute;
        top: 100%;
        left: 0;
        background: #fff;
        min-width: 250px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.2s ease;
        border-radius: 2px;
        border: 1px solid #eaeaea;
        display: flex;
        flex-direction: column;
    }

    .nav-item:hover > .nav-menu-list:not(.level-1) {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    /* Sub-Dropdowns (Level 3+) */
    .nav-item > .nav-menu-list:not(.level-1) > .nav-item > .nav-menu-list {
        top: -1px;
        left: 100%;
        transform: translateX(10px);
    }

    .nav-item > .nav-menu-list:not(.level-1) > .nav-item:hover > .nav-menu-list {
        transform: translateX(0);
    }

    /* Dropdown Items styling */
    .nav-menu-list:not(.level-1) > .nav-item {
        border-bottom: 1px solid #f2f2f2;
    }
    .nav-menu-list:not(.level-1) > .nav-item:last-child {
        border-bottom: none;
    }

    .nav-menu-list:not(.level-1) > .nav-item > .navigation-title {
        display: flex;
        justify-content: space-between;
        padding: 0;
    }

    .nav-menu-list:not(.level-1) > .nav-item > .navigation-title a {
        padding: 12px 20px;
        font-size: 14px;
        width: 100%;
        color: #444;
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
    }

    .nav-menu-list:not(.level-1) > .nav-item:hover > .navigation-title {
        background: #f8f9fc;
    }
    
    .nav-menu-list:not(.level-1) > .nav-item:hover > .navigation-title > a {
        color: #003087;
    }

    .nav-menu-list:not(.level-1) > .nav-item > .navigation-title .nav-arrow {
        transform: rotate(-90deg); /* point right for side submenus */
        margin-right: 15px;
    }

    @@media (min-width: 992px) {
        /* Prevents clicking desktop menu from toggling mobile checkbox */
        .menu-mobile-navigate-wrapper {
            pointer-events: none; 
        }
        .component-content {
            pointer-events: auto;
        }
        .menu-mobile-navigate,
        .menu-humburger {
            display: none !important;
        }
    }
</style>

<div class="component navigation @Model.Styles @Model.GridParameters" id="@Model.Id">
    <label class="menu-mobile-navigate-wrapper" style="width: 100%;">
        <input type="checkbox"
               class="menu-mobile-navigate" />
        <div class="menu-humburger"></div>
        <div class="component-content">
            <nav class="desktop-nav">
                @await Html.PartialAsync("./_NavigationMenu.cshtml", @Model)
            </nav>
        </div>
    </label>
</div>