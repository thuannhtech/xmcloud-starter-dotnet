@model Sitecore.AspNetCore.Starter.Models.BannerSliderFolder

@{
    bool isEditing = Model?.IsEditing ?? false;
    var slides = Model?.BannerSliders?.ToList();
    string sliderId = $"banner-swiper-{Model?.Id ?? "main"}";
    string prevId   = $"{sliderId}-prev";
    string nextId   = $"{sliderId}-next";
    string paginId  = $"{sliderId}-pagin";
    string ppId     = $"{sliderId}-pp";
}

@if (slides != null && slides.Any() || isEditing)
{
    <section class="banner-slider-section component @Model?.Styles @Model?.GridParameters" id="@Model?.Id">
        <div class="swiper banner-swiper"
             id="@sliderId"
             data-slider-id="@sliderId"
             data-prev-id="@prevId"
             data-next-id="@nextId"
             data-pagin-id="@paginId"
             data-pp-id="@ppId"
             data-editing="@isEditing.ToString().ToLower()">

            <div class="swiper-wrapper">
                @if (slides != null)
                {
                    @foreach (var slide in slides)
                    {
                        var bannerSlider = slide.ReadFields<BannerSlider>();
                        var imgSrc  = bannerSlider.Image?.Value?.Src;
                        var ctaHref = bannerSlider.CTA?.Value?.Href;

                        @* Skip slides that have no image *@
                        if (string.IsNullOrWhiteSpace(imgSrc)) { continue; }

                        <div class="swiper-slide banner-slide">
                            @if (!string.IsNullOrWhiteSpace(ctaHref))
                            {
                                <a href="@ctaHref" target="@bannerSlider.CTA!.Value.Target" class="banner-slide__link">
                                    <img class="banner-slide__img" src="@imgSrc" alt="@bannerSlider.Image!.Value.Alt" />
                                </a>
                            }
                            else
                            {
                                <img class="banner-slide__img" src="@imgSrc" alt="@bannerSlider.Image!.Value.Alt" />
                            }
                        </div>
                    }
                }

                @if (isEditing && (slides == null || !slides.Any()))
                {
                    <div class="banner-slide__edit-wrap">
                        <p style="text-align:center; line-height:150px; color:#666;">No Slide, Please click edit slide.</p>
                    </div>
                }
            </div>

            @if (!isEditing)
            {
                <button class="banner-swiper__prev" id="@prevId">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="banner-swiper__next" id="@nextId">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
            }
        </div>

        @if (!isEditing)
        {
            <div class="banner-controls">
                <div class="banner-controls__inner">
                    <div class="banner-swiper__pagination" id="@paginId"></div>
                    <button class="banner-swiper__play-pause" id="@ppId">
                        <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><rect x="5" y="3" width="4" height="18" rx="1"/><rect x="15" y="3" width="4" height="18" rx="1"/></svg>
                        <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="display:none;"><path d="M8 5v14l11-7z"/></svg>
                    </button>
                </div>
            </div>
        }
    </section>

    <script src="~/js/banner-slider.js"></script>
}